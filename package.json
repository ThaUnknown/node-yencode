{
  "name": "@thaunknown/yencode",
  "version": "1.5.1",
  "type": "module",
  "description": "SIMD accelerated yEnc encoder/decoder and CRC32 calculator",
  "keywords": [
    "yenc",
    "yencode",
    "crc32"
  ],
  "files": [
    "y.*",
    "index.*",
    "src/**/*",
    "prebuilds/**/*",
    "crcutil-1.0/**/*"
  ],
  "license": "CC0-1.0",
  "author": "Anime Tosho",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/animetosho/node-yencode.git"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "engines": {
    "node": ">=0.10"
  },
  "scripts": {
    "compile": "tsc --noCheck",
    "install": "node-gyp-build",
    "prebuild": "prebuildify --napi --strip",
    "prebuild-ia32": "prebuildify --napi --strip --arch=ia32"
  },
  "gypfile": true,
  "bugs": {
    "url": "https://github.com/thaunknown/node-yencode/issues"
  },
  "dependencies": {
    "node-gyp-build": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint-config-standard-universal": "^1.0.9",
    "prebuildify": "^6.0.1"
  }
}